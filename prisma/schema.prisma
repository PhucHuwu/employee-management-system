generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
}

enum FixedSchedule {
  SHIFT_8_5
  SHIFT_9_6
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
}

enum ScheduleRequestType {
  OFF_FULL_DAY
  REMOTE_FULL_DAY
  OFF_AM
  OFF_PM
  REMOTE_AM
  REMOTE_PM
  CHANGE_FIXED_SCHEDULE
}

enum ScheduleRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ProjectStatus {
  RUNNING
  PAUSED
  ENDED
}

enum RevenueType {
  FORECAST
  ACTUAL
}

model Department {
  id        String     @id @default(uuid()) @db.Uuid
  name      String     @db.VarChar(255)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]
  users     UserAccount[]
}

model Position {
  id          String     @id @default(uuid()) @db.Uuid
  name        String     @db.VarChar(255)
  description String?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
}

model JobTitle {
  id          String                 @id @default(uuid()) @db.Uuid
  name        String                 @db.VarChar(255)
  levelOrder  Int
  description String?
  active      Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  fromHistory EmployeeTitleHistory[] @relation("OldJobTitle")
  toHistory   EmployeeTitleHistory[] @relation("NewJobTitle")
}

model EmployeeTitleHistory {
  id            String    @id @default(uuid()) @db.Uuid
  effectiveDate DateTime  @map("effective_date") @db.Date
  reason        String?
  createdBy     String    @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  employeeId    String    @map("employee_id") @db.Uuid
  oldJobTitleId String?   @map("old_job_title_id") @db.Uuid
  newJobTitleId String    @map("new_job_title_id") @db.Uuid
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  oldJobTitle   JobTitle? @relation("OldJobTitle", fields: [oldJobTitleId], references: [id], onDelete: SetNull)
  newJobTitle   JobTitle  @relation("NewJobTitle", fields: [newJobTitleId], references: [id], onDelete: Restrict)

  @@unique([employeeId, effectiveDate])
  @@index([employeeId, effectiveDate])
  @@map("employee_title_histories")
}

model Employee {
  id               String                 @id @default(uuid()) @db.Uuid
  fullName         String                 @map("full_name") @db.VarChar(255)
  dob              DateTime               @db.Date
  address          String
  fixedSchedule    FixedSchedule          @map("fixed_schedule")
  employmentStatus EmploymentStatus       @default(ACTIVE) @map("employment_status")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  deletedAt        DateTime?              @map("deleted_at")
  departmentId     String                 @map("department_id") @db.Uuid
  positionId       String                 @map("position_id") @db.Uuid
  department       Department             @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  position         Position               @relation(fields: [positionId], references: [id], onDelete: Restrict)
  dailyReports     DailyReport[]
  scheduleRequests ScheduleRequest[]
  projectMembers   ProjectMember[]
  titleHistories   EmployeeTitleHistory[]

  @@index([departmentId, positionId])
  @@map("employees")
}

model ScheduleRequest {
  id                String                @id @default(uuid()) @db.Uuid
  requestType       ScheduleRequestType   @map("request_type")
  requestDate       DateTime              @map("request_date") @db.Date
  requestedSchedule FixedSchedule?        @map("requested_schedule")
  status            ScheduleRequestStatus @default(PENDING)
  reason            String?
  rejectionReason   String?               @map("rejection_reason")
  approvedBy        String?               @map("approved_by") @db.Uuid
  approvedAt        DateTime?             @map("approved_at")
  createdAt         DateTime              @default(now()) @map("created_at")
  employeeId        String                @map("employee_id") @db.Uuid
  employee          Employee              @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@index([requestDate, status])
  @@map("schedule_requests")
}

model DailyReport {
  id          String    @id @default(uuid()) @db.Uuid
  reportDate  DateTime  @map("report_date") @db.Date
  task        String
  workContent String    @map("work_content")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  employeeId  String    @map("employee_id") @db.Uuid
  projectId   String?   @map("project_id") @db.Uuid
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([employeeId, reportDate, projectId])
  @@index([employeeId, reportDate])
  @@map("daily_reports")
}

model Project {
  id            String            @id @default(uuid()) @db.Uuid
  code          String            @unique @db.VarChar(100)
  name          String            @db.VarChar(255)
  status        ProjectStatus
  startDate     DateTime?         @map("start_date") @db.Date
  endDate       DateTime?         @map("end_date") @db.Date
  description   String?
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  dailyReports  DailyReport[]
  members       ProjectMember[]
  customers     ProjectCustomer[]
  documents     ProjectDocument[]
  revenues      ProjectRevenue[]

  @@map("projects")
}

model ProjectMember {
  id            String    @id @default(uuid()) @db.Uuid
  roleInProject String?   @map("role_in_project") @db.VarChar(100)
  joinedAt      DateTime? @map("joined_at")
  leftAt        DateTime? @map("left_at")
  projectId     String    @map("project_id") @db.Uuid
  employeeId    String    @map("employee_id") @db.Uuid
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Restrict)
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@unique([projectId, employeeId])
  @@map("project_members")
}

model Customer {
  id                String            @id @default(uuid()) @db.Uuid
  companyName       String            @map("company_name") @db.VarChar(255)
  taxCode           String?           @map("tax_code") @db.VarChar(100)
  businessAddress   String?           @map("business_address")
  contactAddress    String?           @map("contact_address")
  country           String?           @db.VarChar(100)
  city              String?           @db.VarChar(100)
  contactName       String?           @map("contact_name") @db.VarChar(255)
  contactTitle      String?           @map("contact_title") @db.VarChar(255)
  contactEmail      String?           @map("contact_email") @db.VarChar(255)
  contactPhone      String?           @map("contact_phone") @db.VarChar(50)
  paymentTerms      String?           @map("payment_terms")
  notes             String?
  cooperationStatus String?           @map("cooperation_status") @db.VarChar(100)
  projects          ProjectCustomer[]

  @@map("customers")
}

model ProjectCustomer {
  id         String   @id @default(uuid()) @db.Uuid
  projectId  String   @map("project_id") @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Restrict)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@unique([projectId, customerId])
  @@map("project_customers")
}

model ProjectDocument {
  id         String   @id @default(uuid()) @db.Uuid
  fileName   String   @map("file_name") @db.VarChar(255)
  storageKey String   @map("storage_key") @db.VarChar(500)
  mimeType   String   @map("mime_type") @db.VarChar(100)
  sizeBytes  BigInt   @map("size_bytes")
  uploadedBy String   @map("uploaded_by") @db.Uuid
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  projectId  String   @map("project_id") @db.Uuid
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Restrict)

  @@map("project_documents")
}

model ProjectRevenue {
  id          String      @id @default(uuid()) @db.Uuid
  periodMonth Int         @map("period_month")
  periodYear  Int         @map("period_year")
  revenueType RevenueType @map("revenue_type")
  amount      Decimal     @db.Decimal(18, 2)
  currency    String      @db.VarChar(10)
  note        String?
  projectId   String      @map("project_id") @db.Uuid
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Restrict)

  @@index([projectId, periodYear, periodMonth])
  @@map("project_revenues")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String?  @map("actor_id") @db.Uuid
  actorRole Role?    @map("actor_role")
  action    String   @db.VarChar(255)
  entityType String  @map("entity_type") @db.VarChar(255)
  entityId  String   @map("entity_id") @db.Uuid
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model UserAccount {
  id                String      @id @default(uuid()) @db.Uuid
  email             String      @unique @db.VarChar(255)
  passwordHash      String      @map("password_hash") @db.VarChar(255)
  role              Role
  active            Boolean     @default(true)
  departmentScopeId String?     @map("department_scope_id") @db.Uuid
  projectScopeIds   String[]    @default([]) @map("project_scope_ids")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  departmentScope   Department? @relation(fields: [departmentScopeId], references: [id], onDelete: SetNull)

  @@index([role, active])
  @@map("user_accounts")
}
